# API Configuration
API_TITLE=Whisper Transcription API
API_VERSION=1.0.0
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Whisper
WHISPER_MODEL=base  # tiny, base, small, medium, large
WHISPER_DEVICE=cpu  # cpu, cuda
WHISPER_COMPUTE_TYPE=int8

# Audio Processing
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FORMATS=wav,mp3,m4a,flac,ogg,wma,aac
SAMPLE_RATE=16000
CHUNK_DURATION=30

# Job Processing
JOB_TIMEOUT=600
MAX_RETRIES=3

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage
